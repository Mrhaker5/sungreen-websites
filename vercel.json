{
  "version": 2,
  "rewrites": [
    { "source": "/about", "destination": "/frontend/about.html" },
    { "source": "/services", "destination": "/frontend/services.html" },
    { "source": "/solar-installation", "destination": "/frontend/solar-installation.html" },
    { "source": "/products", "destination": "/frontend/shop.html" },
    { "source": "/projects", "destination": "/frontend/projects.html" },
    { "source": "/contact", "destination": "/frontend/contact.html" },
    { "source": "/blog", "destination": "/frontend/blog.html" },
    { "source": "/admin/(.*)", "destination": "/frontend/admin/$1" }
  ],
  "routes": [
    { 
      "src": "/(.*\\.(css|js|jpeg|jpg|png|svg|ico))", 
      "dest": "/frontend/$1",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    { 
      "src": "/(.*\\.(xml|txt))", 
      "dest": "/frontend/$1",
      "headers": {
        "Cache-Control": "public, max-age=0, s-maxage=86400, stale-while-revalidate=86400"
      }
    },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}
